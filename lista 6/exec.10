// Online C compiler to run C program online
#include <stdio.h>

int main() {
   float vendas[7];
   int pos, diaMaior = 0;
   float maior;
   
   for (pos = 0; pos < 7; pos++){
       printf ("Digite o número da posição %d: ", pos);
       scanf ("%f", &vendas[pos]);
   }
   maior = vendas[0];
   
   for (pos = 0; pos < 7; pos++){
       if (vendas[pos] > maior){
           maior = vendas[pos];
           diaMaior = pos;
       }
   }
   printf ("\nMaior venda = %.2f no dia %d\n", maior, diaMaior + 1);
   
    return 0;
}