// Online C compiler to run C program online
#include <stdio.h>

int main() {
    int numeros [12];
    int i, pares = 0;
    
    for ( i = 0; i < 12; i++){
    printf ("digite o numero da posicao %d: ", i);
    scanf ("%d", &numeros [i]);
    }
    for (i = 0; i < 12; i++){
        if (numeros[i] % 2 == 0){
            pares++;
        }
    }
    printf ("\nquantidade de pares = %d\n ", pares);
    
  return 0;
}