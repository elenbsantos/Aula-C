// Online C compiler to run C program online
#include <stdio.h>
int main() {
    int numeros[12];
    int pos, pares = 0;
    
    for (pos = 0; pos < 12; pos++){
        printf ("Digite o número da posição %d: ", pos);
        scanf ("%d", &numeros[pos]);
    }
    for (pos = 0; pos < 12; pos++){
        if (numeros[pos] % 2 == 0){
            pares++;
        }
    }
    printf ("\nQuantidade de pares =  %d\n ", pares);
    return 0;
}