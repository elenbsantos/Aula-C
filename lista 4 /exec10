// Leia 5 números e determine o maior e o menor.
#include <stdio.h>

int main() {
    int i, numero;
    int maior, menor;

    printf("Numero 1: ");
    scanf("%d", &numero);

    maior = numero;
    menor = numero;
    
    for (i = 2; i <= 5; i++) {
        printf("Numero %d: ", i);
        scanf("%d", &numero);

        if (numero > maior) {
            maior = numero;
        }
     if (numero < menor) {
            menor = numero;
        }
    }
    printf("\nMaior numero: %d\n", maior);
    printf("Menor numero: %d\n", menor);

    return 0;
}