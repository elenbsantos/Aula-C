// Online C compiler to run C program online
#include <stdio.h>

int main() {
   int prioridade, continuar;
   int baixa = 0, media = 0, alta = 0;
   
   do {
       printf ("Prioridade do chamado. \n");
       printf ("\n1 - Baixa\n");
       printf ("2 - Media\n");
       printf ("3 - Alta\n");
       printf ("\nDigite a prioridade: ");
       scanf("%d", &prioridade);
       
       if (prioridade == 1){
           baixa++;
       
       }else if (prioridade == 2){
           media++;
       
       }else if (prioridade == 3){
           alta++;
           
        }else{
        printf("\nPrioridade invalida.\n");
   }
   printf("\nDeseja continuar? (1 = sim / 0 = não): ");
   scanf("%d", &continuar);
   
   } while (continuar == 1);
   
   printf ("\nBaixa: %d", baixa);
   printf ("\nMedia: %d", media);
   printf ("\nAlta: %d", alta);
   
    return 0;
}