// Online C compiler to run C program online
#include <stdio.h>

int main() {
    float meta, valorMes, total = 0;
    int mesesValidos = 0;
    
    printf ("Digite a meta de economia: ");
    scanf ("f%", &meta);
    
    while (total < meta){
        printf ("Digite o valor economizado no mes; ");
        scanf ("%f", &valorMes);
       
        if (valorMes > 0 ){ 
            total =  total + valorMes; mesesValidos ++;
        }else {
        printf ("valor desconsiderado");
        }
    }
     
     printf ("Total economizado: %.2f", total);
     printf ( "Meses validos: %d", mesesValidos);
        
    
    
     return 0;
}