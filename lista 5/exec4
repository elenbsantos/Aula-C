// Online C compiler to run C program online
#include <stdio.h>

int main() {
   int i, status;
   int concluidas = 0, pendentes = 0;
   
   for (i = 1; i <= 8; i++){
       printf ("Digite os status: ");
       scanf("%d", &status);
       
       if (status == 1){
           concluidas++;
      
       }else{
           pendentes++;
       }
   }
   
   printf("\nConcluidas: %d", concluidas);
   printf("\nPendentes: %d", pendentes);
       
    return 0;
}