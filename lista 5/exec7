// Online C compiler to run C program online
#include <stdio.h>

int main() {
   int i;
   float temperatura;
   int seguras = 0, risco = 0;
   
   for (i = 1; i <= 12; i++){
       printf ("Digite a temperatura: ");
       scanf ("%d", &temperatura);
       
       if (temperatura <= 75){
           seguras++;
           
       } else {
           risco++;
       }
    }
      printf ("\nLeituras seguras: %d", seguras);
      printf ("\nLeituras de risco: %d", risco);
   
    return 0;
}